@startuml integration-events
title <size:16><b>Integration Events</b></size>\n<color:#555>Межсервисные события (MassTransit / RabbitMQ)</color>

' ─── Глобальные настройки стиля ──────────────────────────────────────────────
skinparam defaultFontName "Segoe UI", Arial, sans-serif
skinparam defaultFontSize 12
skinparam roundcorner 10
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam nodesep 50
skinparam ranksep 60

skinparam class {
    BackgroundColor White
    HeaderBackgroundColor #EBF5FB
    BorderColor #2980B9
    BorderThickness 1.2
    ArrowColor #2980B9
    ArrowThickness 1.2
    AttributeFontColor #2C3E50
}

skinparam package {
    BackgroundColor #FAFAFA
    BorderColor #90A4AE
    FontName "Segoe UI", Arial, sans-serif
    FontSize 13
}

skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #FBC02D
    FontColor #4E342E
    BorderThickness 1.2
    roundcorner 6
}

skinparam stereotypeCBackgroundColor #D6EAF8

' ─── Shared Contracts ────────────────────────────────────────────────────────

package "LocMp.Contracts\n(общая библиотека событий)" #F5F5F5 {

    package "Identity Events" #EDE7F6 {
        class UserRegisteredEvent {
            + UserId : Guid
            + Email : string
            + DisplayName : string
            + OccurredAt : DateTimeOffset
        }
        class UserBlockedEvent {
            + UserId : Guid
            + BlockedUntil : DateTimeOffset
            + OccurredAt : DateTimeOffset
        }
        class UserUnblockedEvent {
            + UserId : Guid
            + OccurredAt : DateTimeOffset
        }
        class UserProfileUpdatedEvent {
            + UserId : Guid
            + DisplayName : string
            + AvatarUrl : string?
            + OccurredAt : DateTimeOffset
        }
    }

    package "Catalog Events" #E9F7EF {
        class StockReservedEvent {
            + ProductId : Guid
            + OrderId : Guid
            + ReservedQuantity : int
            + OccurredAt : DateTimeOffset
        }
        class StockReservationFailedEvent {
            + ProductId : Guid
            + OrderId : Guid
            + Reason : string
            + OccurredAt : DateTimeOffset
        }
        class StockReleasedEvent {
            + ProductId : Guid
            + OrderId : Guid
            + ReleasedQuantity : int
            + OccurredAt : DateTimeOffset
        }
        class StockDepletedEvent {
            + ProductId : Guid
            + SellerId : Guid
            + ProductName : string
            + OccurredAt : DateTimeOffset
        }
    }

    package "Order Events" #EDE7F6 {
        class OrderPlacedEvent {
            + OrderId : Guid
            + BuyerId : Guid
            + SellerId : Guid
            + TotalAmount : decimal
            + OccurredAt : DateTimeOffset
        }
        class OrderStatusChangedEvent {
            + OrderId : Guid
            + BuyerId : Guid
            + SellerId : Guid
            + FromStatus : string
            + ToStatus : string
            + OccurredAt : DateTimeOffset
        }
        class OrderCompletedEvent {
            + OrderId : Guid
            + BuyerId : Guid
            + SellerId : Guid
            + CourierId : Guid?
            + OccurredAt : DateTimeOffset
        }
        class StockReserveRequestEvent {
            + ProductId : Guid
            + OrderId : Guid
            + Quantity : int
            + OccurredAt : DateTimeOffset
        }
    }

    package "Review Events" #FDEDEC {
        class RatingAggregateUpdatedEvent {
            + SubjectId : Guid
            + SubjectType : string
            + NewAverage : decimal
            + ReviewCount : int
            + OccurredAt : DateTimeOffset
        }
    }

    package "Catalog Events" #E9F7EF {
        class ProductViewedEvent {
            + ProductId : Guid
            + SellerId : Guid
            + ViewerId : Guid?
            + OccurredAt : DateTimeOffset
        }
    }

    package "Dispute Events" #FFF3E0 {
        class DisputeOpenedEvent {
            + DisputeId : Guid
            + OrderId : Guid
            + InitiatorId : Guid
            + OccurredAt : DateTimeOffset
        }
        class DisputeResolvedEvent {
            + DisputeId : Guid
            + OrderId : Guid
            + ResolutionMinutes : int
            + OccurredAt : DateTimeOffset
        }
    }
}

' ─── Notes ───────────────────────────────────────────────────────────────────

note as PublisherNote
  <b>Кто публикует:</b>
  IdentityService  → UserRegisteredEvent
                     UserBlockedEvent
                     UserUnblockedEvent
                     UserProfileUpdatedEvent
  ─────────────────────────────────────────
  CatalogService   → StockReservedEvent
                     StockReservationFailedEvent
                     StockReleasedEvent
                     StockDepletedEvent
                     ProductViewedEvent
  ─────────────────────────────────────────
  OrderService     → OrderPlacedEvent
                     OrderStatusChangedEvent
                     OrderCompletedEvent
                     StockReserveRequestEvent
                     DisputeOpenedEvent
                     DisputeResolvedEvent
  ─────────────────────────────────────────
  ReviewService    → RatingAggregateUpdatedEvent
end note

note as ConsumerNote
  <b>Кто потребляет:</b>
  CatalogService:
    • StockReserveRequestEvent    → резервирует StockQuantity
    • StockReleasedEvent          → освобождает резерв
    • RatingAggregateUpdatedEvent → обновляет SellerReadModel
  ─────────────────────────────────────────
  OrderService:
    • StockReservedEvent          → Order → Confirmed
    • StockReservationFailedEvent → Order → Cancelled
    • UserBlockedEvent            → отменяет Pending заказы
  ─────────────────────────────────────────
  ReviewService:
    • OrderCompletedEvent → разблокирует отзыв для покупателя
  ─────────────────────────────────────────
  AnalyticsService (потребляет всё):
    • OrderPlacedEvent            → PlatformDailySummary, GeographicActivity
    • OrderStatusChangedEvent     → SellerSalesSummary (cancelled/disputed)
    • OrderCompletedEvent         → SellerSalesSummary, TopProduct, SellerLeaderboard
    • StockDepletedEvent          → StockAlert
    • RatingAggregateUpdatedEvent → SellerRatingHistory
    • UserRegisteredEvent         → PlatformDailySummary.NewRegistrations
    • UserBlockedEvent            → PlatformDailySummary.BlockedUsers
    • ProductViewedEvent          → ProductViewCounter
    • DisputeOpenedEvent          → DisputeSummary.OpenedCount
    • DisputeResolvedEvent        → DisputeSummary (resolved + время решения)
  ─────────────────────────────────────────
  NotificationService:
    • UserRegisteredEvent         → создаёт Preference
    • OrderPlacedEvent            → уведомление продавцу
    • OrderStatusChangedEvent     → уведомление покупателю
    • OrderCompletedEvent         → предложение написать отзыв
    • StockDepletedEvent          → уведомление продавцу
    • RatingAggregateUpdatedEvent → уведомление о новом отзыве
end note

@enduml
