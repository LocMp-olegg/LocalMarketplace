@startuml analytics-service-flow
title <size:16><b>AnalyticsService</b></size>\n<color:#555>Поток обработки запросов (:5006)</color>

' ─── Стиль ───────────────────────────────────────────────────────────────────
skinparam defaultFontName "Segoe UI", Arial, sans-serif
skinparam defaultFontSize 12
skinparam roundcorner 10
skinparam shadowing false

skinparam component {
    BackgroundColor White
    BorderColor #E65100
    FontColor #2C3E50
    BorderThickness 1.2
}
skinparam rectangle {
    BorderColor #E65100
    BorderThickness 1.5
    FontColor #BF360C
    FontStyle bold
    BackgroundColor transparent
}
skinparam database {
    BackgroundColor #FBE9E7
    BorderColor #E65100
}
skinparam queue {
    BackgroundColor #F3E5F5
    BorderColor #6A1B9A
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #FBC02D
    FontColor #4E342E
    BorderThickness 1.2
    roundcorner 6
}

' ─── Внешние акторы ──────────────────────────────────────────────────────────

component "API Gateway\n:5000" as Gateway #ECEFF1

rectangle "RabbitMQ  (входящие события — 16)" #F3E5F5 {
    queue "UserRegisteredEvent\nUserBlockedEvent\nUserProfileUpdatedEvent\n← IdentityService" as EV_Identity

    queue "OrderPlacedEvent\nOrderStatusChangedEvent\nOrderCompletedEvent\nDisputeOpenedEvent\nDisputeResolvedEvent\n← OrderService" as EV_Order

    queue "ProductCreatedEvent\nProductViewedEvent\nStockDepletedEvent\nFavoriteChangedEvent\n← CatalogService" as EV_Catalog

    queue "ReviewCreatedEvent\nRatingAggregateUpdatedEvent\n← ReviewService" as EV_Review
}

' ─── AnalyticsService ────────────────────────────────────────────────────────

rectangle "**AnalyticsService  :5006**" #FFF3E0 {

  rectangle "**Api Layer**" #FFE0B2 {
    component "**SellerDashboardController**\nGET /api/seller-dashboard/sales\n    ?periodType=Daily|Weekly|Monthly  (Seller)\nGET /api/seller-dashboard/top-products\n    ?periodType  ?topCount  (Seller)\nGET /api/seller-dashboard/rating-history\n    ?lastDays  (Seller)\nGET /api/seller-dashboard/stock-alerts\n    ?onlyUnacknowledged  (Seller)\nPOST /api/seller-dashboard/stock-alerts/{id}/acknowledge  (Seller)\nGET /api/seller-dashboard/product-views\n    ?productId  (Seller)\nGET /api/seller-dashboard/product-ratings  (Seller)" as SellerDashCtrl

    component "**PlatformDashboardController**\nGET /api/platform-dashboard/daily-summary\n    ?date  (Admin)\nGET /api/platform-dashboard/seller-leaderboard\n    ?periodType  (Admin)\nGET /api/platform-dashboard/dispute-summary\n    ?date  (Admin)\nGET /api/platform-dashboard/geographic-activity\n    ?periodType  (Admin)" as AdminDashCtrl
  }

  rectangle "**Application Layer  (MediatR)**" {

    component "**MediatR Pipeline**\nLoggingBehavior\n→ ValidationBehavior (FluentValidation)\n→ CachingBehavior (ICacheableQuery → Redis)" as Pipeline

    rectangle "Queries  (только чтение — нет Commands в HTTP)" #FFF3E0 {
      component "GetSellerSalesQuery  (SellerId из JWT)\nGetSellerTopProductsQuery\nGetSellerRatingHistoryQuery\nGetSellerStockAlertsQuery\nGetProductViewCountersQuery\nGetSellerProductRatingsQuery" as QSeller

      component "GetPlatformDailySummaryQuery  (Admin)\nGetSellerLeaderboardQuery  (Admin)\nGetDisputeSummaryQuery  (Admin)\nGetGeographicActivityQuery  (Admin)" as QAdmin
    }

    rectangle "Consumers  (MassTransit) — 16 консьюмеров" #FDEBD0 {
      component "**UserRegisteredConsumer**\n→ PlatformDailySummary.NewRegistrations++\n**UserBlockedConsumer**\n→ PlatformDailySummary.BlockedUsers++\n**UserProfileUpdatedConsumer**\n→ обновляет SellerLeaderboard.SellerName" as ConsIdentity

      component "**OrderPlacedConsumer**\n→ PlatformDailySummary.TotalOrders++\n→ Redis SADD active-buyers:{date} BuyerId\n→ Redis SADD active-sellers:{date} SellerId\n**OrderStatusChangedConsumer**\n→ PlatformDailySummary.CancelledOrders++\n→ SellerSalesSummary.CancelledCount++" as ConsOrderPlaced

      component "**OrderCompletedConsumer**\n→ SellerSalesSummary.TotalRevenue += Amount\n→ SellerSalesSummary.CompletedCount++\n→ TopProduct.TotalSold++, TotalRevenue++\n→ SellerLeaderboard.TotalRevenue++\n→ PlatformDailySummary.CompletedOrders++\n→ PlatformDailySummary.GMV += Amount\n(обновляет Daily + Weekly + Monthly)" as ConsOrderDone

      component "**DisputeOpenedConsumer**\n→ DisputeSummary.OpenedCount++\n→ PlatformDailySummary.DisputedOrders++\n**DisputeResolvedConsumer**\n→ DisputeSummary.ResolvedCount++\n→ DisputeSummary.BuyerFavored/SellerFavored++\n→ DisputeSummary.AverageResolutionMinutes пересчёт" as ConsDispute

      component "**ProductCreatedConsumer**\n→ PlatformDailySummary.NewProducts++\n**ProductViewedConsumer**\n→ ProductViewCounter.TotalViews++\n→ ProductViewCounter.ViewsToday++\n→ TopProduct.ViewCount++\n**FavoriteChangedConsumer**\n→ TopProduct.FavoriteCount += delta" as ConsCatalog

      component "**StockDepletedConsumer**\n→ StockAlert создаётся\n   {SellerId, ProductId, AlertType=OutOfStock}" as ConsStock

      component "**ReviewCreatedConsumer**\n→ SellerRatingHistory (NewReviewsToday++)\n**RatingAggregateUpdatedConsumer**\n→ SellerRatingHistory запись за сегодня\n→ TopProduct.AverageRating обновляется\n→ SellerLeaderboard.AverageRating обновляется" as ConsReview
    }

    rectangle "Background Services" #FFF8EE {
      component "**LeaderboardComputeBackgroundService**\n(каждые 6 часов)\n→ SELECT SellerLeaderboard GROUP BY Seller\n→ RANK() OVER (ORDER BY TotalRevenue)\n→ обновляет RevenueRank, OrderCountRank\n**ViewCountResetBackgroundService**\n→ каждую полночь: ViewsToday → 0\n→ каждый понедельник: ViewsThisWeek → 0" as BgSvc
    }
  }

  rectangle "**Infrastructure Layer**" #FFE0B2 {
    component "**AnalyticsDbContext**\n(EF Core 10)\nUNIQUE INDEX на (SellerId, PeriodType, PeriodStart)\nдля инкрементального UPSERT" as DbCtx
    component "**Redis Adapter**\n(IDistributedCache)\nactive-buyers:{date} SADD — уникальные покупатели\nactive-sellers:{date} SADD — уникальные продавцы\nаналитические кэши запросов" as RedisAdapt
  }
}

' ─── Внешние системы ─────────────────────────────────────────────────────────

database "**PostgreSQL** :5430\nschema: analytics\n(SellerSalesSummaries, TopProducts,\nSellerRatingHistory, StockAlerts,\nProductViewCounters, PlatformDailySummaries,\nSellerLeaderboards, DisputeSummaries,\nGeographicActivities)" as DB #FBE9E7
database "**Redis** :6379" as Redis #EAFAF1

' ─── Связи ───────────────────────────────────────────────────────────────────

' Gateway → API
Gateway -[#E65100,bold]-> SellerDashCtrl : HTTP + JWT (Seller)
Gateway -[#E65100,bold]-> AdminDashCtrl  : HTTP + JWT (Admin)

' Consumed events → Consumers
EV_Identity -[#B71C1C,dashed]-> ConsIdentity   : consume
EV_Order    -[#B71C1C,dashed]-> ConsOrderPlaced : consume
EV_Order    -[#B71C1C,dashed]-> ConsOrderDone   : consume
EV_Order    -[#B71C1C,dashed]-> ConsDispute     : consume
EV_Catalog  -[#B71C1C,dashed]-> ConsCatalog     : consume
EV_Catalog  -[#B71C1C,dashed]-> ConsStock       : consume
EV_Review   -[#B71C1C,dashed]-> ConsReview      : consume

' API → MediatR
SellerDashCtrl -[#E65100]-> Pipeline : ISender.Send()
AdminDashCtrl  -[#E65100]-> Pipeline

' Pipeline → Handlers
Pipeline -[#E65100]-> QSeller
Pipeline -[#E65100]-> QAdmin

' Queries → Infrastructure
QSeller -[#795548]-> DbCtx
QSeller -[#00838F,dashed]-> RedisAdapt
QAdmin  -[#795548]-> DbCtx
QAdmin  -[#00838F,dashed]-> RedisAdapt

' Consumers → Infrastructure
ConsIdentity    -[#795548]-> DbCtx
ConsOrderPlaced -[#795548]-> DbCtx
ConsOrderPlaced -[#00838F,dashed]-> RedisAdapt : SADD active users
ConsOrderDone   -[#795548]-> DbCtx
ConsDispute     -[#795548]-> DbCtx
ConsCatalog     -[#795548]-> DbCtx
ConsStock       -[#795548]-> DbCtx
ConsReview      -[#795548]-> DbCtx

' Background → Infrastructure
BgSvc -[#795548]-> DbCtx
BgSvc -[#00838F,dashed]-> RedisAdapt : сброс ViewsToday/Week

' Infrastructure → External
DbCtx      -[#BF360C,bold]-> DB
RedisAdapt -[#00838F,dashed]-> Redis

' ─── Заметки ─────────────────────────────────────────────────────────────────

note right of Pipeline
  AnalyticsService только
  потребляет события и предоставляет
  read-only REST API.
  Не публикует никаких событий в MQ.
  Не вызывает другие сервисы по HTTP.
end note

note right of ConsOrderDone
  Инкрементальное обновление (не пересчёт):
  SellerSalesSummary обновляется
  трижды за одно событие:
  → Daily   (PeriodStart = сегодня)
  → Weekly  (PeriodStart = начало недели)
  → Monthly (PeriodStart = начало месяца)
  UNIQUE INDEX гарантирует один агрегат
  на период — INSERT OR UPDATE паттерн.
end note

note right of QSeller
  SellerId берётся из JWT-токена
  (не из query-параметра) — продавец
  видит только свои данные.
  Admin-запросы принимают SellerId
  как параметр или возвращают
  данные по всей платформе.
end note

note bottom of BgSvc
  LeaderboardComputeBackgroundService:
  RANK нельзя считать инкрементально —
  нужно знать все результаты.
  Запускается каждые 6 часов.
  Читает SellerLeaderboard, вычисляет
  RANK по TotalRevenue и OrderCount,
  обновляет RevenueRank, OrderCountRank.

  ViewCountResetBackgroundService:
  Сбрасывает ViewsToday → 0 каждую полночь.
  Сбрасывает ViewsThisWeek → 0 каждый пн.
end note

note right of ConsOrderPlaced
  Подсчёт уникальных участников в Redis:
  SADD analytics:buyers:{date} {BuyerId}
  SADD analytics:sellers:{date} {SellerId}
  TTL: 48 часов

  В конце дня (или по запросу):
  SCARD → PlatformDailySummary
           .ActiveBuyers / .ActiveSellers
end note

' ─── Легенда ─────────────────────────────────────────────────────────────────

legend bottom
  <b>Условные обозначения</b>
  |= Цвет |= Тип связи |
  |= <color:#E65100>━━━━━</color> |= HTTP запрос / ISender.Send() (MediatR) |
  |= <color:#B71C1C>- - -</color> |= Потребление события из RabbitMQ |
  |= <color:#795548>━━━━━</color> |= Чтение / запись через EF Core |
  |= <color:#00838F>- - -</color> |= Redis (уникальные счётчики + кэш, пунктир) |
  |= <color:#BF360C>━━━━━</color> |= PostgreSQL (schema: analytics) |
endlegend

@enduml
