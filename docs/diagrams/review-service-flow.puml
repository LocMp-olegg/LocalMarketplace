@startuml review-service-flow
title <size:16><b>ReviewService</b></size>\n<color:#555>Поток обработки запросов (:5004)</color>

' ─── Стиль ───────────────────────────────────────────────────────────────────
skinparam defaultFontName "Segoe UI", Arial, sans-serif
skinparam defaultFontSize 12
skinparam roundcorner 10
skinparam shadowing false

skinparam component {
    BackgroundColor White
    BorderColor #C0392B
    FontColor #2C3E50
    BorderThickness 1.2
}
skinparam rectangle {
    BorderColor #C0392B
    BorderThickness 1.5
    FontColor #922B21
    FontStyle bold
    BackgroundColor transparent
}
skinparam database {
    BackgroundColor #FADBD8
    BorderColor #B03A2E
}
skinparam queue {
    BackgroundColor #F3E5F5
    BorderColor #6A1B9A
}
skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #FBC02D
    FontColor #4E342E
    BorderThickness 1.2
    roundcorner 6
}

' ─── Внешние акторы ──────────────────────────────────────────────────────────

component "API Gateway\n:5000" as Gateway #ECEFF1

rectangle "RabbitMQ  (входящие события)" #F3E5F5 {
    queue "OrderCompletedEvent\n← OrderService" as EV_Completed
    queue "DisputeResolvedEvent\n← OrderService" as EV_Dispute
}

' ─── ReviewService ───────────────────────────────────────────────────────────

rectangle "**ReviewService  :5004**" #FDEDEC {

  rectangle "**Api Layer**" #FADBD8 {
    component "**ReviewsController**\nGET /api/reviews  (SubjectType + SubjectId, с фильтром рейтинга/сорт)\nGET /api/reviews/{id}\nGET /api/reviews/by-order/{orderId}  (Auth)\nGET /api/reviews/my  (Auth)\nGET /api/reviews/allowed  (Auth) — что можно оценить\nGET /api/reviews/admin  (Admin) — очередь модерации\nPOST /api/reviews  (Auth)\nPUT /api/reviews/{id}  (Auth)\nDELETE /api/reviews/{id}  (Auth)\nPOST /api/reviews/{id}/moderate  (Admin, isVisible)\nPOST|PUT|DELETE /api/reviews/{id}/response  (Seller)\nPOST /api/reviews/{id}/photos\nDELETE /api/reviews/photos/{photoId}" as ReviewCtrl

    component "**RatingController**\nGET /api/ratings  (SubjectType + SubjectId)\nGET /api/ratings/many  (bulk: список SubjectId)" as RatingCtrl
  }

  rectangle "**Application Layer  (MediatR)**" {

    component "**MediatR Pipeline**\nLoggingBehavior\n→ ValidationBehavior (FluentValidation)\n→ CachingBehavior (ICacheableQuery)" as Pipeline

    rectangle "Commands" #FDEDEC {
      component "CreateReviewCommand\n— проверяет AllowedReview (OrderId + BuyerId)\n— проверяет отсутствие дубля (UNIQUE OrderId)\n— создаёт Review\n— пересчитывает RatingAggregate\n— публикует ReviewCreatedEvent\n— публикует RatingAggregateUpdatedEvent" as CmdCreate

      component "UpdateReviewCommand  /  DeleteReviewCommand\nModerateReviewCommand  (Admin → IsVisible)\nRespondToReviewCommand  (Seller → ReviewResponse)\nUpdateReviewResponseCommand  /  DeleteReviewResponseCommand" as CmdOther

      component "UploadReviewPhotosCommand\nDeleteReviewPhotoCommand" as CmdPhoto
    }

    rectangle "Queries" #FEF9E7 {
      component "GetReviewsQuery  (paged, sort, filter by rating)\nGetReviewByIdQuery  /  GetReviewByOrderQuery\nGetMyReviewsQuery\nGetAllowedReviewsQuery  (читает AllowedReview)\nGetReviewsForModerationQuery  (Admin)" as QReviews

      component "GetRatingAggregateQuery  (ICacheableQuery)\nGetBulkRatingAggregatesQuery" as QRating
    }

    rectangle "Consumers  (MassTransit)" #FDF2F2 {
      component "**OrderCompletedConsumer**\n← OrderCompletedEvent\n→ создаёт AllowedReview:\n  { OrderId, BuyerId, SellerId, CourierId? }\n→ идемпотентно (INSERT OR IGNORE)" as ConsCompleted

      component "**DisputeResolvedConsumer**\n← DisputeResolvedEvent\n→ если исход BuyerFavored:\n  проверяет AllowedReview,\n  создаёт авто-Review от имени системы\n→ пересчитывает RatingAggregate" as ConsDispute
    }
  }

  rectangle "**Infrastructure Layer**" #FADBD8 {
    component "**ReviewDbContext**\n(EF Core 10)\nСоставной PK: (SubjectId, SubjectType)\nв RatingAggregates" as DbCtx
    component "**MassTransitEventBus**\n(IEventBus)" as EventBus
    component "**MinIO Adapter**\n(IStorageService)\nbucket: review-media" as MinIOAdapt
  }
}

' ─── Внешние системы ─────────────────────────────────────────────────────────

database "**PostgreSQL** :5430\nschema: reviews\n(Reviews, ReviewPhotos, ReviewResponses,\nRatingAggregates, AllowedReviews)" as DB #FADBD8
component "**MinIO** :9000\nbucket: review-media" as MinIO #FFF3E0
queue "**RabbitMQ** :5672\n(исходящие события)" as MQ_OUT #F3E5F5

' ─── Связи ───────────────────────────────────────────────────────────────────

' Gateway → API
Gateway -[#C0392B,bold]-> ReviewCtrl : HTTP + JWT
Gateway -[#C0392B,bold]-> RatingCtrl : HTTP

' Consumed events → Consumers
EV_Completed -[#B71C1C,dashed]-> ConsCompleted : consume
EV_Dispute   -[#B71C1C,dashed]-> ConsDispute   : consume

' API → MediatR
ReviewCtrl -[#C0392B]-> Pipeline : ISender.Send()
RatingCtrl -[#C0392B]-> Pipeline

' Pipeline → Handlers
Pipeline -[#C0392B]-> CmdCreate
Pipeline -[#C0392B]-> CmdOther
Pipeline -[#C0392B]-> CmdPhoto
Pipeline -[#C0392B]-> QReviews
Pipeline -[#C0392B]-> QRating

' Commands → Infrastructure
CmdCreate -[#795548]-> DbCtx
CmdCreate -[#6A1B9A,bold]-> EventBus
CmdOther  -[#795548]-> DbCtx
CmdOther  -[#6A1B9A,bold]-> EventBus
CmdPhoto  -[#795548]-> DbCtx
CmdPhoto  -[#795548]-> MinIOAdapt

' Queries → Infrastructure
QReviews -[#795548]-> DbCtx
QRating  -[#795548]-> DbCtx

' Consumers → Infrastructure
ConsCompleted -[#795548]-> DbCtx
ConsDispute   -[#795548]-> DbCtx
ConsDispute   -[#6A1B9A,bold]-> EventBus

' Infrastructure → External
DbCtx      -[#B03A2E,bold]-> DB
MinIOAdapt -[#E65100,dashed]-> MinIO
EventBus   -[#6A1B9A,bold]-> MQ_OUT

' ─── Заметки ─────────────────────────────────────────────────────────────────

note right of EventBus
  Публикует 2 события:
  • ReviewCreatedEvent
    (ReviewId, SubjectId, SubjectType,
     ReviewerId, SellerId, Rating)
  • RatingAggregateUpdatedEvent
    (SubjectId, SubjectType,
     NewAverage, ReviewCount,
     1..5 star distribution)
end note

note right of CmdCreate
  Бизнес-правила CreateReview:
  1. AllowedReview с OrderId + BuyerId
     должна существовать
     (создаётся OrderCompletedConsumer)
  2. Отзыв по этому OrderId ещё не написан
     (UNIQUE INDEX на OrderId)
  3. SubjectType: Seller / Product / Courier
  4. Rating: 1..5

  После создания Review:
  → UPDATE RatingAggregate
    (инкрементально: AVG, counts)
  → публикует оба события
end note

note right of QRating
  RatingAggregate — pre-computed,
  составной PK (SubjectId, SubjectType).
  Один агрегат на каждый субъект:
  • Seller → SellerId
  • Product → ProductId
  • Courier → CourierId
  Потребляется CatalogService и AnalyticsService
  через RatingAggregateUpdatedEvent.
end note

note bottom of ConsDispute
  DisputeResolvedEvent.Outcome == BuyerFavored:
  → система пишет отзыв 1★ от имени покупателя
    с комментарием из Resolution

  DisputeResolvedEvent.Outcome == SellerFavored:
  → никакой авто-генерации отзыва
end note

note right of ConsCompleted
  Идемпотентность:
  INSERT INTO AllowedReviews
  ON CONFLICT (OrderId) DO NOTHING

  AllowedReview хранит:
  OrderId, BuyerId, SellerId, CourierId?
  — чтобы покупатель мог оценить
    продавца, товар и курьера
    за один завершённый заказ.
end note

' ─── Легенда ─────────────────────────────────────────────────────────────────

legend bottom
  <b>Условные обозначения</b>
  |= Цвет |= Тип связи |
  |= <color:#C0392B>━━━━━</color> |= HTTP запрос / ISender.Send() (MediatR) |
  |= <color:#6A1B9A>━━━━━</color> |= Публикация события → RabbitMQ (MassTransit) |
  |= <color:#B71C1C>- - -</color> |= Потребление события из RabbitMQ |
  |= <color:#795548>━━━━━</color> |= Чтение / запись через EF Core |
  |= <color:#E65100>- - -</color> |= MinIO объектное хранилище (пунктир) |
endlegend

@enduml
