@startuml system-overview
title LocalMarketplace — Архитектурный обзор системы

' ─── Глобальные настройки ───
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam nodesep 60
skinparam ranksep 80

skinparam actor {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
}
skinparam component {
    BackgroundColor White
    BorderColor #455A64
    FontName Arial
}
skinparam database {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
}
skinparam queue {
    BackgroundColor #F3E5F5
    BorderColor #6A1B9A
}
skinparam rectangle {
    BorderColor #B0BEC5
    BorderStyle dashed
    BackgroundColor transparent
}
skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

' ─── СЛОЙ 1: Actors ──────────────────────────────────────────────────────────
together {
    actor "Покупатель" as Buyer
    actor "Продавец" as Seller
    actor "Курьер-сосед" as Courier
}

' ─── СЛОЙ 2: API Gateway ─────────────────────────────────────────────────────
component "**API Gateway**\nOcelot  :5000" as Gateway #ECEFF1

' ─── СЛОЙ 3: Microservices ───────────────────────────────────────────────────
rectangle "Микросервисы" {
    component "**IdentityService**\n:5001\n─────────────────\nПользователи, роли\nАутентификация\nDuende IdentityServer" as Identity   #EDE7F6
    component "**CatalogService**\n:5002\n─────────────────\nТовары, категории\nОстатки, избранное\nГеофильтрация" as Catalog      #E8F5E9
    component "**OrderService**\n:5003\n─────────────────\nКорзина, заказы\nСтатусы, курьер\nСпоры" as Orders      #E8EAF6
    component "**ReviewService**\n:5004\n─────────────────\nОтзывы, рейтинги\nМодерация" as Reviews     #FBE9E7
    component "**NotificationService**\n:5005\n─────────────────\nIn-App уведомления\nEmail (MailKit)\nПредпочтения" as Notifs      #E0F7FA
    component "**AnalyticsService**\n:5006\n─────────────────\nДашборд продавца\nДашборд Admin\nPre-computed" as Analytics  #FFF3E0
    component "**ChatService**\n:5007\n─────────────────\nЧат заказа и поддержки\nSignalR WebSocket\nRedis backplane" as Chat      #E8F5E9

    Identity -[hidden]right-> Catalog
    Catalog -[hidden]right-> Orders
    Orders -[hidden]right-> Reviews
    Reviews -[hidden]right-> Notifs
    Notifs -[hidden]right-> Analytics
    Analytics -[hidden]right-> Chat
}

' ─── Инфраструктура ──────────────────────────────────────────────────────────
queue "**RabbitMQ**\n:15672\nMassTransit" as MQ
database "**Redis**\n:6379" as Redis
component "**MailHog**\n:8025 Web\n:1025 SMTP\n(dev only)" as MailHog #FFF3E0

' ─── СЛОЙ 4: Databases ───────────────────────────────────────────────────────
rectangle "**PostgreSQL  :5430**\n(один инстанс, разные схемы)" #E3F2FD {
    database "schema:\npublic + media" as DBIdentity
    database "schema:\ncatalog" as DBCatalog
    database "schema:\norders" as DBOrders
    database "schema:\nreviews" as DBReviews
    database "schema:\nnotifs" as DBNotifs
    database "schema:\nanalytics" as DBAnalytics
    database "schema:\nchat" as DBChat

    DBIdentity -[hidden]right-> DBCatalog
    DBCatalog -[hidden]right-> DBOrders
    DBOrders -[hidden]right-> DBReviews
    DBReviews -[hidden]right-> DBNotifs
    DBNotifs -[hidden]right-> DBAnalytics
    DBAnalytics -[hidden]right-> DBChat
}

' ═════════════════════════════════════════════════════════════════════════════
' СТРЕЛКИ
' ═════════════════════════════════════════════════════════════════════════════

' ── Клиенты → Gateway (синий) ──
Buyer   -[#1565C0,bold]down->  Gateway : <color:#1565C0>HTTPS</color>
Seller  -[#1565C0,bold]down->  Gateway : <color:#1565C0>HTTPS</color>
Courier -[#1565C0,bold]down->  Gateway : <color:#1565C0>HTTPS</color>

' ── Gateway → Services (зелёный) ──
Gateway -[#2E7D32,bold]down-> Identity  : <color:#2E7D32>/api/identity/**</color>\n<color:#2E7D32>/connect/**</color>
Gateway -[#2E7D32,bold]down-> Catalog   : <color:#2E7D32>/api/catalog/**</color>
Gateway -[#2E7D32,bold]down-> Orders    : <color:#2E7D32>/api/orders/**</color>
Gateway -[#2E7D32,bold]down-> Reviews   : <color:#2E7D32>/api/reviews/**</color>
Gateway -[#2E7D32,bold]down-> Notifs    : <color:#2E7D32>/api/notifications/**</color>
Gateway -[#2E7D32,bold]down-> Analytics : <color:#2E7D32>/api/analytics/**</color>
Gateway -[#2E7D32,bold]down-> Chat      : <color:#2E7D32>/api/chats/**</color>\n<color:#2E7D32>/hubs/chat (WS)</color>

' ── Синхронный HTTP между сервисами (оранжевый, пунктир) ──
Orders -[#E65100,dashed]left-> Catalog  : <color:#E65100>GET /products/{id}/stock</color>\n<color:#E65100>POST /products/{id}/reserve</color>
Orders -[#E65100,dashed]left-> Identity : <color:#E65100>GET /users/{id}</color>\n<color:#E65100>(снепшот имени)</color>

' ── Redis cache (бирюзовый, пунктир) ──
Catalog -[#00838F,dashed]up-> Redis : <color:#00838F>products, categories</color>\n<color:#00838F>profiles</color>
Orders  -[#00838F,dashed]up-> Redis : <color:#00838F>cart:{userId}</color>
Notifs  -[#00838F,dashed]up-> Redis : <color:#00838F>notif:prefs, notif:unread</color>
Chat    -[#00838F,dashed]up-> Redis : <color:#00838F>SignalR backplane</color>

' ── Email (пурпурный, пунктир) ──
Notifs -[#AD1457,dashed]right-> MailHog : <color:#AD1457>SMTP :1025</color>

' ── Публикация событий в MQ (фиолетовый) ──
Identity -[#6A1B9A,bold]down-> MQ : <color:#6A1B9A>UserRegisteredEvent</color>\n<color:#6A1B9A>UserBecameSellerEvent</color>\n<color:#6A1B9A>UserBlockedEvent</color>\n<color:#6A1B9A>UserUnblockedEvent</color>\n<color:#6A1B9A>UserProfileUpdatedEvent</color>
Catalog  -[#6A1B9A,bold]down-> MQ : <color:#6A1B9A>StockReservedEvent</color>\n<color:#6A1B9A>StockReleasedEvent</color>\n<color:#6A1B9A>StockDepletedEvent</color>\n<color:#6A1B9A>StockReservationFailedEvent</color>\n<color:#6A1B9A>ProductCreatedEvent</color>\n<color:#6A1B9A>ProductViewedEvent</color>\n<color:#6A1B9A>ProductRestockedEvent</color>\n<color:#6A1B9A>FavoriteChangedEvent</color>
Orders   -[#6A1B9A,bold]down-> MQ : <color:#6A1B9A>StockReserveRequestEvent</color>\n<color:#6A1B9A>OrderPlacedEvent</color>\n<color:#6A1B9A>OrderStatusChangedEvent</color>\n<color:#6A1B9A>OrderCompletedEvent</color>\n<color:#6A1B9A>DisputeOpenedEvent</color>\n<color:#6A1B9A>DisputeResolvedEvent</color>
Reviews  -[#6A1B9A,bold]down-> MQ : <color:#6A1B9A>RatingAggregateUpdatedEvent</color>\n<color:#6A1B9A>ReviewCreatedEvent</color>
Chat     -[#6A1B9A,bold]down-> MQ : <color:#6A1B9A>ChatMessageSentEvent</color>

' ── Потребление событий из MQ (красный, пунктир) ──
MQ -[#B71C1C,dashed]up-> Catalog   : <color:#B71C1C>StockReserveRequestEvent</color>\n<color:#B71C1C>→ зарезервировать остаток</color>\n<color:#B71C1C>UserProfileUpdatedEvent</color>\n<color:#B71C1C>→ обновить SellerReadModel</color>\n<color:#B71C1C>RatingAggregateUpdatedEvent</color>\n<color:#B71C1C>→ рейтинг в SellerReadModel</color>
MQ -[#B71C1C,dashed]up-> Orders    : <color:#B71C1C>StockReservedEvent → подтвердить</color>\n<color:#B71C1C>StockReservationFailedEvent → отменить</color>\n<color:#B71C1C>UserBlockedEvent → отменить заказы</color>
MQ -[#B71C1C,dashed]up-> Reviews   : <color:#B71C1C>OrderCompletedEvent</color>\n<color:#B71C1C>→ разблокировать отзыв</color>\n<color:#B71C1C>DisputeResolvedEvent</color>\n<color:#B71C1C>→ авто-отзыв</color>
MQ -[#B71C1C,dashed]up-> Notifs    : <color:#B71C1C>UserRegisteredEvent</color>\n<color:#B71C1C>UserBecameSellerEvent</color>\n<color:#B71C1C>UserBlocked/Unblocked</color>\n<color:#B71C1C>OrderPlaced/Status/Completed</color>\n<color:#B71C1C>DisputeOpened/Resolved</color>\n<color:#B71C1C>StockDepletedEvent</color>\n<color:#B71C1C>ProductRestockedEvent</color>\n<color:#B71C1C>RatingAggregateUpdatedEvent</color>\n<color:#B71C1C>ReviewCreatedEvent</color>
MQ -[#B71C1C,dashed]up-> Analytics : <color:#B71C1C>OrderPlaced/Status/Completed</color>\n<color:#B71C1C>DisputeOpened/Resolved</color>\n<color:#B71C1C>StockDepletedEvent</color>\n<color:#B71C1C>ProductViewed/Created</color>\n<color:#B71C1C>FavoriteChangedEvent</color>\n<color:#B71C1C>RatingAggregateUpdatedEvent</color>\n<color:#B71C1C>ReviewCreatedEvent</color>
MQ -[#B71C1C,dashed]up-> Chat      : <color:#B71C1C>OrderPlacedEvent → создать чат</color>\n<color:#B71C1C>OrderStatusChangedEvent → закрыть</color>\n<color:#B71C1C>UserBlockedEvent → закрыть чаты</color>

' ── Запись / чтение БД (коричневый) ──
Identity  -[#795548]down-> DBIdentity
Catalog   -[#795548]down-> DBCatalog
Orders    -[#795548]down-> DBOrders
Reviews   -[#795548]down-> DBReviews
Notifs    -[#795548]down-> DBNotifs
Analytics -[#795548]down-> DBAnalytics
Chat      -[#795548]down-> DBChat

' ─── Легенда ─────────────────────────────────────────────────────────────────
legend bottom
  **Условные обозначения:**
  <color:#1565C0>■</color> HTTPS от клиента → Gateway
  <color:#2E7D32>■</color> Роутинг Gateway → Сервис
  <color:#E65100>■</color> Синхронный HTTP между сервисами (пунктир)
  <color:#6A1B9A>■</color> Публикация события в RabbitMQ
  <color:#B71C1C>■</color> Потребление события из RabbitMQ (пунктир)
  <color:#795548>■</color> Чтение / запись в БД
  <color:#00838F>■</color> Redis cache (пунктир)
  <color:#AD1457>■</color> Email через MailHog SMTP (пунктир, dev only)
endlegend

@enduml
