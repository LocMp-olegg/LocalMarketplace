{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "LocalMarketplaceDb": "Host=localhost;Port=5430;Database=LocalMarketplaceDb;Username=postgres;Password=123Qq123",
    "RabbitMq": "amqp://guest:guest@localhost:5672",
    "Redis": "localhost:6379"
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": "Information",
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{TraceId}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {
            "MinimumLevel": {
              "Default": "Information",
              "Override": {
                "Microsoft": "Warning",
                "Microsoft.EntityFrameworkCore": "Warning",
                "Microsoft.AspNetCore": "Warning",
                "System": "Warning",
                "Duende": "Warning"
              }
            },
            "WriteTo": [
              {
                "Name": "File",
                "Args": {
                  "path": "../Logs/identity-.log",
                  "rollingInterval": "Day",
                  "retainedFileCountLimit": 14,
                  "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] [{TraceId}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
                }
              }
            ]
          }
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "../Logs/identity-errors-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "restrictedToMinimumLevel": "Error",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] [{TraceId}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "IdentityServer": {
    "Clients": [
      {
        "ClientId": "default-client",
        "AllowedScopes": [
          "openid",
          "profile",
          "api",
          "offline_access",
          "IdentityServerApi"
        ],
        "AccessTokenLifetime": 3600
      }
    ]
  },
  "Minio": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "BucketName": "locmp-identity",
    "UseSSL": false,
    "PublicEndpoint": "localhost:9000"
  },
  "JwtAuthenticationOptions": {
    "Authority": "http://localhost:5001"
  },
  "SwaggerDocOptions": {
    "Name": "v1",
    "Version": "v1.0.0",
    "Title": "LocMp.Identity.Api",
    "Description": "Identity microservice for Local Marketplace",
    "Servers": [
      {
        "Url": "http://localhost:5001",
        "Description": "Local Development"
      }
    ]
  }
}
