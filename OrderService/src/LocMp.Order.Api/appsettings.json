{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "LocalMarketplaceDb": "Host=localhost;Port=5430;Database=LocalMarketplaceDb;Username=postgres;Password=123Qq123",
    "RabbitMq": "amqp://guest:guest@localhost:5672",
    "Redis": "localhost:6379"
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": "Debug",
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{TraceId}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "../Logs/orders-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] [{TraceId}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "../Logs/orders-errors-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "restrictedToMinimumLevel": "Error",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] [{TraceId}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Minio": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "BucketName": "locmp-orders",
    "UseSSL": false,
    "PublicEndpoint": "localhost:9000"
  },
  "Services": {
    "Catalog": "http://localhost:5002/"
  },
  "Dispute": {
    "AutoResolveDays": 14
  },
  "JwtAuthenticationOptions": {
    "Authority": "http://localhost:5001"
  },
  "SwaggerDocOptions": {
    "Name": "v1",
    "Version": "v1.0.0",
    "Title": "LocMp.Order.Api",
    "Description": "Order microservice for Local Marketplace",
    "Servers": [
      {
        "Url": "http://localhost:5003",
        "Description": "Local Development"
      }
    ]
  }
}
