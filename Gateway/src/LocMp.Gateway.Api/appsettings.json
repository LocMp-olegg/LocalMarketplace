{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "../Logs/log.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "CorsPoliticsOptions": {
    "AllowedOrigins": "http://localhost:5173"
  },
  "AuthenticationOptions": {
    "Audience": "http://localhost:5173",
    "Authority": "http://localhost:5001"
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  }
}
